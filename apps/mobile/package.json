{
  "name": "@boundly/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "android:release": "cd android && ./gradlew assembleRelease",
    "android:apk": "cd android && ./gradlew assembleRelease",
    "eas:android:preview": "npx eas-cli build --platform android --profile preview",
    "eas:android:production": "npx eas-cli build --platform android --profile production",
    "eas:build:list": "npx eas-cli build:list --limit 10",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"Add eslint in next step\"",
    "test": "echo \"Add tests in next step\""
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@boundly/domain": "workspace:*",
    "@boundly/native-enforcement": "workspace:*",
    "@boundly/persistence": "workspace:*",
    "@boundly/ui-kit": "workspace:*",
    "expo": "^52.0.33",
    "expo-asset": "~11.0.5",
    "expo-sqlite": "~15.1.4",
    "react": "^18.3.1",
    "react-native": "^0.76.9",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "typescript": "^5.7.3"
  }
}
